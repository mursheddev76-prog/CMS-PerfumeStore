@model PerfumeStore.Web.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Customer Login";
    var authMessage = TempData["AuthMessage"]?.ToString();
}

<section class="customer-auth-shell">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5">
                <p class="eyebrow mb-3">Customer Account</p>
                <h1 class="mb-3">Sign in to manage your orders and saved scents.</h1>
                <p class="text-muted mb-4">Your account now includes wishlist saving, order history, and a cleaner checkout flow tied to your customer email.</p>

                <div class="auth-benefit-list">
                    <div class="auth-benefit-item">
                        <i class="bi bi-bag-check"></i>
                        <div>
                            <strong>Order history</strong>
                            <p>Review placed orders and delivery method details any time.</p>
                        </div>
                    </div>
                    <div class="auth-benefit-item">
                        <i class="bi bi-heart"></i>
                        <div>
                            <strong>Wishlist</strong>
                            <p>Save fragrances from the landing page, catalog, and product detail pages.</p>
                        </div>
                    </div>
                    <div class="auth-benefit-item">
                        <i class="bi bi-lightning-charge"></i>
                        <div>
                            <strong>Faster checkout</strong>
                            <p>Your account email and name are prefilled during checkout.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card customer-auth-card border-0">
                    <div class="card-body p-4 p-lg-5">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                            <div>
                                <h2 class="h3 mb-1">Welcome back</h2>
                                <p class="text-muted mb-0">Use your customer email and password to continue.</p>
                            </div>
                            <a class="btn btn-outline-dark" asp-action="Register">Create account</a>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(authMessage))
                        {
                            <div class="alert alert-success">@authMessage</div>
                        }

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <input asp-for="LoginType" type="hidden" />
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                            <div class="mb-3">
                                <label asp-for="Username" class="form-label">Email</label>
                                <input asp-for="Username" class="form-control form-control-lg" placeholder="you@example.com" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Password" class="form-label">Password</label>
                                <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-dark btn-lg w-100">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
                            </button>
                        </form>

                        <div class="text-center mt-4 pt-4 border-top">
                            <a href="/" class="text-decoration-none">Continue shopping</a>
                            <span class="mx-2 text-muted">•</span>
                            <a href="/catalog" class="text-decoration-none">Browse catalog</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
