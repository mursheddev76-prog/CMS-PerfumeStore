@model PerfumeStore.Web.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Customer Login";
}

<section class="py-5" style="background: linear-gradient(135deg, #fdfcfb 0%, #f5f3f0 100%); min-height: 100vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row align-items-center g-5" style="max-width: 1000px; margin: 0 auto;">
            <!-- Left Side - Brand & Benefits -->
            <div class="col-lg-5">
                <div class="mb-5">
                    <a href="/" class="text-decoration-none mb-4 d-inline-block">
                        <h2 class="fw-bold mb-0">
                            <i class="bi bi-flower1 me-2" style="color: var(--primary);"></i>Perfume Store
                        </h2>
                    </a>
                    <p class="text-muted">Your destination for luxury fragrances</p>
                </div>

                <h3 class="mb-4 fw-bold">Access Your Account</h3>
                <p class="text-muted mb-5">Sign in to view your orders, track shipments, and manage your preferences.</p>

                <div class="d-flex align-items-start gap-3 mb-4">
                    <div style="min-width: 40px; width: 40px; height: 40px; background: rgba(198, 135, 64, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i class="bi bi-bag-check" style="color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Order History</strong>
                        <small class="text-muted">Track all your purchases</small>
                    </div>
                </div>

                <div class="d-flex align-items-start gap-3 mb-4">
                    <div style="min-width: 40px; width: 40px; height: 40px; background: rgba(198, 135, 64, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i class="bi bi-heart" style="color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Wishlist</strong>
                        <small class="text-muted">Save your favorite scents</small>
                    </div>
                </div>

                <div class="d-flex align-items-start gap-3 mb-4">
                    <div style="min-width: 40px; width: 40px; height: 40px; background: rgba(198, 135, 64, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i class="bi bi-truck" style="color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Fast Delivery</strong>
                        <small class="text-muted">Real-time shipment tracking</small>
                    </div>
                </div>

                <div class="d-flex align-items-start gap-3">
                    <div style="min-width: 40px; width: 40px; height: 40px; background: rgba(198, 135, 64, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i class="bi bi-percent" style="color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Exclusive Deals</strong>
                        <small class="text-muted">Member-only discounts</small>
                    </div>
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-md" style="border-radius: 16px;">
                    <div class="card-body p-5">
                        <!-- Tabs -->
                        <ul class="nav nav-tabs border-0 mb-5" role="tablist" style="gap: 1rem;">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active border-0 fw-bold" id="login-tab" data-bs-toggle="tab" data-bs-target="#login-content" type="button" role="tab" aria-controls="login-content" aria-selected="true">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link border-0 fw-bold" id="register-tab" data-bs-toggle="tab" data-bs-target="#register-content" type="button" role="tab" aria-controls="register-content" aria-selected="false">
                                    <i class="bi bi-person-plus me-2"></i>Create Account
                                </button>
                            </li>
                        </ul>

                        <!-- Login Tab -->
                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="login-content" role="tabpanel" aria-labelledby="login-tab">
                                <h4 class="mb-1 fw-bold">Welcome Back</h4>
                                <p class="text-muted mb-4">Sign in to continue shopping</p>

                                <form asp-action="Login" method="post">
                                    <input asp-for="LoginType" type="hidden" />
                                    <div class="mb-4">
                                        <label asp-for="Username" class="form-label fw-bold">Email or Username</label>
                                        <input asp-for="Username" class="form-control form-control-lg" placeholder="you@example.com" />
                                        <span asp-validation-for="Username" class="text-danger small d-block mt-1"></span>
                                    </div>

                                    <div class="mb-4">
                                        <label asp-for="Password" class="form-label fw-bold">Password</label>
                                        <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="••••••••" />
                                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe">
                                            <label class="form-check-label" for="rememberMe">
                                                Remember me
                                            </label>
                                        </div>
                                        <a href="#" class="text-decoration-none small">Forgot password?</a>
                                    </div>

                                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold mb-4" style="border-radius: 10px;">
                                        <i class="bi bi-unlock me-2"></i>Sign In
                                    </button>
                                </form>

                                <div class="text-center mb-4">
                                    <div class="position-relative mb-4">
                                        <hr />
                                        <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">OR</span>
                                    </div>
                                </div>

                                <button class="btn btn-outline-dark w-100 mb-2" style="border-radius: 10px;">
                                    <i class="bi bi-google me-2"></i>Continue with Google
                                </button>
                                <button class="btn btn-outline-dark w-100" style="border-radius: 10px;">
                                    <i class="bi bi-facebook me-2"></i>Continue with Facebook
                                </button>
                            </div>

                            <!-- Register Tab -->
                            <div class="tab-pane fade" id="register-content" role="tabpanel" aria-labelledby="register-tab">
                                <h4 class="mb-1 fw-bold">Create Your Account</h4>
                                <p class="text-muted mb-4">Join us and discover luxury fragrances</p>

                                <form method="post">
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">First Name</label>
                                            <input type="text" name="firstName" class="form-control form-control-lg" placeholder="John" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Last Name</label>
                                            <input type="text" name="lastName" class="form-control form-control-lg" placeholder="Doe" />
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Email Address</label>
                                        <input type="email" name="email" class="form-control form-control-lg" placeholder="you@example.com" />
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Password</label>
                                        <input type="password" name="password" class="form-control form-control-lg" placeholder="••••••••" />
                                        <small class="text-muted d-block mt-2">At least 8 characters with uppercase, lowercase, and numbers</small>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Confirm Password</label>
                                        <input type="password" name="confirmPassword" class="form-control form-control-lg" placeholder="••••••••" />
                                    </div>

                                    <div class="form-check mb-4">
                                        <input class="form-check-input" type="checkbox" id="agreeTerms">
                                        <label class="form-check-label" for="agreeTerms">
                                            I agree to the <a href="#" class="text-decoration-none">Terms & Conditions</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
                                        </label>
                                    </div>

                                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold mb-4" style="border-radius: 10px;">
                                        <i class="bi bi-person-plus me-2"></i>Create Account
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="text-center mt-4 pt-3 border-top">
                            <p class="text-muted small mb-0">
                                <a href="/" class="text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                                </a>
                                <span class="mx-2">•</span>
                                <a href="/catalog" class="text-decoration-none">Browse Catalog</a>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Trust Badges -->
                <div class="row g-3 mt-4">
                    <div class="col-4 text-center">
                        <div class="mb-2">
                            <i class="bi bi-shield-check" style="font-size: 1.5rem; color: var(--primary);"></i>
                        </div>
                        <small class="text-muted d-block">Secure &amp; Safe</small>
                    </div>
                    <div class="col-4 text-center">
                        <div class="mb-2">
                            <i class="bi bi-lock" style="font-size: 1.5rem; color: var(--primary);"></i>
                        </div>
                        <small class="text-muted d-block">Encrypted Data</small>
                    </div>
                    <div class="col-4 text-center">
                        <div class="mb-2">
                            <i class="bi bi-clock-history" style="font-size: 1.5rem; color: var(--primary);"></i>
                        </div>
                        <small class="text-muted d-block">24/7 Support</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .shadow-md {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
    }

    .nav-tabs .nav-link {
        color: var(--text-secondary);
        padding-bottom: 0.75rem;
        border-bottom: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .nav-tabs .nav-link:hover {
        color: var(--primary);
    }

    .nav-tabs .nav-link.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
        background: none;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 0.2rem rgba(198, 135, 64, 0.1);
    }

    .btn-dark:hover {
        background-color: var(--primary);
        border-color: var(--primary);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
