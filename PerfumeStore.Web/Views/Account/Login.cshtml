@model PerfumeStore.Web.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Admin Login";
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="row w-100 g-4" style="max-width: 900px;">
        <!-- Left Side - Branding -->
        <div class="col-lg-6 d-flex flex-column justify-content-center">
            <div class="mb-5">
                <h1 class="fw-bold mb-3">
                    <i class="bi bi-lock-fill me-2" style="color: var(--primary);"></i>Admin Portal
                </h1>
                <p class="h5 text-muted mb-4">Perfume Store Control Center</p>
                <p class="text-muted">Manage your product catalog, orders, payments, and customer data from a single dashboard.</p>
            </div>

            <div class="mt-5">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div style="width: 50px; height: 50px; background: rgba(198, 135, 64, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-graph-up" style="font-size: 1.5rem; color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Real-time Analytics</strong>
                        <small class="text-muted">Monitor sales and inventory</small>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3 mb-4">
                    <div style="width: 50px; height: 50px; background: rgba(198, 135, 64, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-box-seam" style="font-size: 1.5rem; color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Product Management</strong>
                        <small class="text-muted">Update inventory and pricing</small>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <div style="width: 50px; height: 50px; background: rgba(198, 135, 64, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-credit-card" style="font-size: 1.5rem; color: var(--primary);"></i>
                    </div>
                    <div>
                        <strong class="d-block">Payment Options</strong>
                        <small class="text-muted">Configure delivery & payments</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <h2 class="mb-1 fw-bold">Welcome Back</h2>
                    <p class="text-muted mb-4">Sign in to your admin account</p>

                    <form asp-action="Login" method="post">
                        <input asp-for="LoginType" type="hidden" />
                        <div class="mb-4">
                            <label asp-for="Username" class="form-label fw-bold">Username</label>
                            <input asp-for="Username" class="form-control form-control-lg" placeholder="Enter your username" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Password</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Remember me
                            </label>
                        </div>

                        <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold mb-3">
                            <i class="bi bi-unlock me-2"></i>Sign In
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">
                            <a href="/" class="text-decoration-none">Back to Store</a>
                        </p>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4 border-0" role="alert">
                <i class="bi bi-info-circle me-2"></i>
                <small>
                    <strong>Demo credentials:</strong> Use your admin username and password to access the control panel.
                </small>
            </div>
        </div>
    </div>
</div>

<style>
    .min-vh-100 {
        background: linear-gradient(135deg, #fdfcfb 0%, #f5f3f0 100%);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
