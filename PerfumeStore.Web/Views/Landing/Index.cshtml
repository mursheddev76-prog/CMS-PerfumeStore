@model PerfumeStore.Web.Models.ViewModels.LandingPageViewModel

@{
    ViewData["Title"] = "Perfume Atelier – Luxury Fragrances";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<!-- Hero Section -->
<section class="hero" style="background-image:url('@Model.Hero.BackgroundImageUrl'); background-size:cover;">
    <div class="hero-overlay"></div>
    <div class="hero-content container text-center text-white">
        <p class="eyebrow">Luxury · Artisan Scents</p>
        <h1>@Model.Hero.Title</h1>
        <p class="lead">@Model.Hero.Subtitle</p>

        <div class="hero-ctas mt-4">
            <a class="btn btn-lg btn-primary" href="@Model.Hero.PrimaryCtaLink">@Model.Hero.PrimaryCtaText</a>
            <a class="btn btn-lg btn-outline-light" href="@Model.Hero.SecondaryCtaLink">@Model.Hero.SecondaryCtaText</a>
        </div>

        <div class="hero-highlights mt-5">
            @foreach (var highlight in Model.CustomerHighlights)
            {
                <span class="badge">@highlight</span>
            }
        </div>
    </div>
</section>

<!-- Featured Products Section -->
<section class="container py-5">
    <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-4 mb-5">
        <div>
            <h2>Featured Scents</h2>
            <p class="text-muted">Hand-picked by our master perfumer. Updated live from the admin panel.</p>
        </div>
        <a class="btn btn-outline-dark" href="/catalog">
            <span>Browse Collection</span>
            <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>

    <div class="row g-4">
        @foreach (var product in Model.Featured)
        {
            <div class="col-lg-4">
                <article class="product-card">
                    <div class="product-image" style="background-image:url('@product.ImageUrl')">
                        @if (product.IsNewArrival)
                        {
                            <span class="badge">New Arrival</span>
                        }
                    </div>

                    <div class="product-body">
                        <p class="text-muted">@product.Category</p>
                        <h3>@product.Name</h3>
                        <p class="small text-muted">@product.Description</p>

                        <div class="pricing my-3">
                            @if (product.DiscountPrice.HasValue)
                            {
                                <span class="price-discount">@product.DiscountPrice.Value.ToString("C")</span>
                                <span class="price-original">@product.Price.ToString("C")</span>
                            }
                            else
                            {
                                <span class="price">@product.Price.ToString("C")</span>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <form asp-controller="Checkout" asp-action="AddToCart" method="post" class="flex-grow-1">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button class="btn btn-dark w-100" type="submit">
                                    <i class="bi bi-bag-check me-2"></i>Add to Cart
                                </button>
                            </form>
                            <button class="btn btn-outline-secondary" data-product-id="@product.Id" data-role="quick-view" title="Quick View">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
</section>

<!-- Why Choose Us -->
<section class="container py-5 my-5">
    <div class="section-heading text-center mb-5">
        <h2>Why Choose Perfumier</h2>
        <p class="text-muted">Crafted for discerning fragrance enthusiasts</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="fulfillment-badge">
                <i class="bi bi-shield-check"></i>
                <h4>Premium Selection</h4>
                <p>Curated fragrances from master perfumers worldwide</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="fulfillment-badge">
                <i class="bi bi-lightning-charge"></i>
                <h4>Fast Delivery</h4>
                <p>Premium packaging and swift, secure shipping</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="fulfillment-badge">
                <i class="bi bi-heart"></i>
                <h4>Expert Support</h4>
                <p>Personalized scent recommendations and service</p>
            </div>
        </div>
    </div>
</section>

<!-- Trending Now Section -->
<section class="bg-light py-5">
    <div class="container">
        <div class="section-heading text-center mb-5">
            <h2>Trending Now</h2>
            <p class="text-muted">Best-selling fragrances powered by real-time analytics</p>
        </div>

        <div class="row g-4">
            @foreach (var product in Model.Trending)
            {
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm">
                        <div style="height: 250px; background-color: #f0f0f0; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="w-100 h-100" style="object-fit: cover;">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                    <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <p class="text-muted small text-uppercase">@product.Category</p>
                            <h5 class="card-title fw-bold">@product.Name</h5>
                            <p class="text-muted small flex-grow-1">@product.Description</p>
                            
                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <strong class="h5 mb-0">@(product.DiscountPrice ?? product.Price).ToString("C")</strong>
                                <a class="btn btn-sm btn-dark" href="/catalog?q=@product.Name">
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Bespoke CTA Section -->
<section class="cta-panel text-center text-white py-5">
    <div class="container">
        <p class="eyebrow mb-3">Bespoke Studio</p>
        <h2 class="mb-3">Need personalized scent matching or premium gifting?</h2>
        <p class="mb-4">Let our fragrance experts guide you to your signature scent.</p>
        <a class="btn btn-outline-light btn-lg" href="/checkout">
            <i class="bi bi-calendar-heart me-2"></i>Book Your Consultation
        </a>
    </div>
</section>

<!-- Newsletter Signup -->
<section class="container py-5 my-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-6">
            <h3 class="fw-bold mb-3">Get Exclusive Offers</h3>
            <p class="text-muted">Subscribe to receive early access to new collections, exclusive discounts, and fragrance tips from our perfume experts.</p>
        </div>
        <div class="col-lg-6">
            <form class="d-flex gap-2">
                <input type="email" class="form-control form-control-lg rounded-pill" placeholder="Enter your email" required>
                <button type="submit" class="btn btn-dark btn-lg rounded-pill px-4">Subscribe</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.perfumierReturnUrl = "@returnUrl";
    </script>
    <script src="/js/landing.js"></script>
}
